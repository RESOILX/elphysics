{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/RESOILX/elphysics/schema/circuit.schema.json",
  "title": "elphysics Circuit Verification Input (DC)",
  "description": "elphysics.verify() / POST /verify が受け取る直流回路 JSON の入力契約。トップレベルキー dc_circuit を持つこと。terminals を指定すると合成抵抗モード、ref_node を指定すると電源・制約解析モード。",
  "type": "object",
  "oneOf": [
    { "required": ["dc_circuit"] }
  ],
  "properties": {
    "dc_circuit": { "$ref": "#/definitions/dc_circuit" }
  },
  "definitions": {
    "dc_circuit": {
      "description": "直流回路。terminals=合成抵抗モード / ref_node=電源・制約解析モード。",
      "type": "object",
      "required": ["nodes", "components"],
      "anyOf": [
        { "required": ["terminals"] },
        { "required": ["ref_node"] }
      ],
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "question": { "type": "string" },
        "nodes": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "components": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "from", "to"],
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string", "enum": ["resistor", "wire", "voltage_source"] },
              "resistance_ohm": { "type": "number" },
              "voltage_v": { "type": ["number", "null"] },
              "rated_current_a": { "type": "number" },
              "from": { "type": "string" },
              "to": { "type": "string" }
            }
          }
        },
        "terminals": {
          "type": "object",
          "required": ["pos", "neg"],
          "properties": {
            "pos": { "type": "string" },
            "neg": { "type": "string" }
          }
        },
        "ref_node": { "type": "string" },
        "constraints": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "component_id", "voltage_v"],
            "properties": {
              "type": { "type": "string", "enum": ["voltage_across"] },
              "component_id": { "type": "string" },
              "voltage_v": { "type": "number" }
            }
          }
        },
        "find": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
